# Global
ENV=dev
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/bmls
REQUEST_TIMEOUT_SECONDS=30
EXTERNAL_API_RETRY_COUNT=3
EXTERNAL_API_RETRY_BACKOFF_SECONDS=1
SIMILARITY_THRESHOLD=0.70

# OpenAI-compatible endpoint for GPT-5-mini services
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
EXTRACTION_MODEL=gpt-5-mini
OCR_MODEL=gpt-5-mini
TRANSLATION_MODEL=gpt-5-mini
EMBEDDING_MODEL=text-embedding-3-small

# OCR defaults
DEFAULT_OCR_PROVIDER=pytesseract
TESSERACT_CMD=/usr/bin/tesseract

# Service ports
LICENSE_EXTRACTION_PORT=8001
REFERENCE_INGESTION_PORT=8002
